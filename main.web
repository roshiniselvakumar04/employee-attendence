
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #f4f6f9;
}
header {
    background-color: #2c3e50;
    color: white;
    padding: 15px;
    text-align: center;
}
.form-section,
.table-section {
    background-color: white;
    margin: 20px;
    padding: 20px;
    border-radius: 8px;
}
table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 15px;
}
th {
    background-color: #244b72;
    color: white;
    padding: 10px;
}
td {
    padding: 10px;
    text-align: center;
    border: 1px solid #ccc;
}
.Good {
    background-color: rgb(149, 149, 229);
    color: white;
    padding: 5px 10px;
    border-radius: 5px;
}
.Poor {
    background-color: rgb(122, 24, 24);
    color: rgb(172, 125, 186);
    padding: 5px 10px;
    border-radius: 5px;
}
@media (max-width: 600px) {
    table, th, td {
        font-size: 12px;
    }
    .section {
        margin: 10px;
        padding: 10px;
    }
}
